{
  "name": "blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "deploy": "npm run build:deploy",
    "build:deploy": "npm run build && git add public/sitemap-0.xml && git commit -m 'Update sitemap' && git push",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "check": "biome check ./src",
    "format": "biome format ./src --write",
    "format:check": "biome format ./src --check",
    "ci-check": "biome check ./src && tsc --noEmit && next build",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "update": "npm update",
    "outdated": "npm outdated",
    "clean": "rm -rf .next node_modules package-lock.json",
    "reinstall": "npm run clean && npm install",
    "type-check": "tsc --noEmit",
    "test:build": "npm run build && npm run start",
    "analyze": "ANALYZE=true npm run build",
    "prepare": "husky",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome lint --write",
      "biome format --write"
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/core": "^3.22.2",
    "@tiptap/extension-blockquote": "^3.22.2",
    "@tiptap/extension-bold": "^3.22.2",
    "@tiptap/extension-bullet-list": "^3.22.2",
    "@tiptap/extension-code": "^3.22.2",
    "@tiptap/extension-code-block": "^3.22.2",
    "@tiptap/extension-document": "^3.22.2",
    "@tiptap/extension-heading": "^3.22.2",
    "@tiptap/extension-history": "^3.22.2",
    "@tiptap/extension-italic": "^3.22.2",
    "@tiptap/extension-link": "^3.22.2",
    "@tiptap/extension-list-item": "^3.22.2",
    "@tiptap/extension-ordered-list": "^3.22.2",
    "@tiptap/extension-paragraph": "^3.22.2",
    "@tiptap/extension-strike": "^3.22.2",
    "@tiptap/extension-text": "^3.22.2",
    "@tiptap/extension-underline": "^3.22.2",
    "@tiptap/pm": "^3.4.4",
    "@tiptap/react": "^3.22.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.1",
    "html-react-parser": "^6.0.0",
    "html-to-text": "^9.0.5",
    "lightningcss": "^1.32.0",
    "lucide-react": "^1.7.0",
    "microcms-js-sdk": "^3.3.0",
    "next": "^16.2.2",
    "next-sitemap": "^4.2.3",
    "plaiceholder": "^3.0.0",
    "react": "^19.2.1",
    "react-datepicker": "^9.1.0",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.72.1",
    "react-server-dom-parcel": "^19.2.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.13",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/gtag.js": "^0.0.20",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "baseline-browser-mapping": "^2.10.16",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
